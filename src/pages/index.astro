---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.jsx';
import HeroNarrative from '../components/HeroNarrative.jsx';
import ToolMarquee from '../components/ToolMarquee.astro';
import BentoSystems from '../components/BentoSystems.jsx';
import UtilityLab from '../components/UtilityLab.jsx';
import CreativeStudio from '../components/CreativeStudio.jsx';
import HighTicketProof from '../components/HighTicketProof.jsx';
import CareerArchitecture from '../components/CareerArchitecture.jsx';
---

<Layout title="Nikhil Raj PK | Systems Led Growth Architect">
  <div class="fixed top-0 left-0 h-1 bg-zapier z-[60]" id="pb"></div>
  <Navigation client:load />
  
  <main class="relative">
    <HeroNarrative client:load />
    <ToolMarquee />
    <BentoSystems client:visible />
    <UtilityLab client:visible />
    <CreativeStudio client:visible />
    
    {/* The Climax: Deep Stone-950 */}
    <HighTicketProof client:visible />

    {/* The Archive: Back to Clean Paper/White */}
    <CareerArchitecture client:visible />

    <section id="fit" class="py-40 px-6 text-center bg-white border-t border-stone-100">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-6xl font-bold mb-12 tracking-tighter italic font-serif text-stone-900">
          Ready to scale?
        </h2>
        <a href="mailto:nrajpk@outlook.com" class="bg-zapier text-white px-12 py-5 rounded-full font-bold uppercase tracking-widest text-xs shadow-2xl hover:bg-stone-900 transition-all">
          Start a Conversation
        </a>
      </div>
    </section>
  </main>
</Layout>